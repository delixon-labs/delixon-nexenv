{
  "// INSTRUCCIONES": "Copia este archivo a .vscode/settings.json (ese archivo es personal, no va al repo)",

  "workbench.colorTheme": "Tokyo Night",
  "workbench.iconTheme": "material-icon-theme",
  "workbench.colorCustomizations": {
    "[Tokyo Night]": {
      "editor.background": "#1a1b2e",
      "sideBar.background": "#181926",
      "sideBar.border": "#3b3f51",
      "activityBar.background": "#13141f",
      "activityBar.border": "#3b3f51",
      "panel.background": "#181926",
      "panel.border": "#3b3f51",
      "terminal.background": "#181926",
      "titleBar.activeBackground": "#13141f",
      "titleBar.border": "#3b3f51",
      "tab.activeBackground": "#1a1b2e",
      "tab.inactiveBackground": "#13141f",
      "tab.border": "#3b3f51",
      "editorGroupHeader.tabsBackground": "#13141f",
      "editorGroupHeader.tabsBorder": "#3b3f51",
      "statusBar.background": "#13141f",
      "statusBar.border": "#3b3f51"
    }
  },

  "terminal.integrated.fontFamily": "JetBrainsMono Nerd Font",
  "terminal.integrated.fontSize": 13,
  "terminal.integrated.defaultProfile.windows": "PowerShell (Nexenv)",
  "terminal.integrated.profiles.windows": {
    "PowerShell (Nexenv)": {
      "source": "PowerShell",
      "args": ["-NoExit", "-File", "${workspaceFolder}/.devenv/terminal-init.ps1"],
      "icon": "terminal-powershell"
    },
    "Git Bash (Nexenv)": {
      "path": "C:\\Program Files\\Git\\bin\\bash.exe",
      "args": ["--init-file", "${workspaceFolder}/.devenv/terminal-init.sh"],
      "icon": "terminal-bash"
    }
  },
  "terminal.integrated.inheritEnv": false,

  "editor.fontSize": 13,
  "editor.fontFamily": "JetBrainsMono Nerd Font, 'Courier New', monospace",
  "editor.fontLigatures": true,
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.formatOnSave": true,
  "editor.rulers": [100],
  "editor.minimap.enabled": false,
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": true,

  "files.insertFinalNewline": false,
  "files.trimFinalNewlines": true,
  "files.trimTrailingWhitespace": true,
  "files.eol": "\n",
  "files.exclude": {
    "**/node_modules": true,
    "**/src-tauri/target": true
  },

  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit",
      "source.organizeImports": "explicit"
    }
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit"
    }
  },
  "[rust]": {
    "editor.defaultFormatter": "rust-lang.rust-analyzer",
    "editor.formatOnSave": true
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },

  "rust-analyzer.checkOnSave": true,
  "rust-analyzer.check.command": "clippy",

  "prettier.semi": true,
  "prettier.singleQuote": false,
  "prettier.tabWidth": 2,
  "prettier.printWidth": 100,
  "prettier.trailingComma": "es5",

  "eslint.validate": ["javascript", "typescript", "typescriptreact"],

  "git.enableSmartCommit": true,
  "git.autofetch": true,
  "chat.editor.enabled": false,
  "breadcrumbs.enabled": true,
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false
}
