# Entorno de Delixon
# Copiar este archivo como .env.local y rellenar los valores
# .env.local NUNCA debe subirse al repositorio

# Entorno de ejecución: development | production
DELIXON_ENV=development

# Nivel de logs: debug | info | warn | error
DELIXON_LOG_LEVEL=debug

# Carpeta de datos de Delixon (dejar vacío para usar la ruta por defecto del sistema)
# En desarrollo: usar ./dev-data para no tocar datos reales
DELIXON_DATA_DIR=./dev-data
