# Entorno de Nexenv
# Copiar este archivo como .env.local y rellenar los valores
# .env.local NUNCA debe subirse al repositorio

# Entorno de ejecucion: development | production
NEXENV_ENV=development

# Nivel de logs: debug | info | warn | error
NEXENV_LOG_LEVEL=debug

# Carpeta de datos de Nexenv (dejar vacio para usar la ruta por defecto del sistema)
# En desarrollo: usar ./dev-data para no tocar datos reales
NEXENV_DATA_DIR=./dev-data
