#!/usr/bin/env node
/* eslint-env node */

const { execFileSync } = require("child_process");
const { join } = require("path");

const ext = process.platform === "win32" ? ".exe" : "";
const binary = join(__dirname, `nexenv${ext}`);

try {
  execFileSync(binary, process.argv.slice(2), { stdio: "inherit" });
} catch (error) {
  if (error.status !== undefined) {
    process.exit(error.status);
  }
  console.error("Nexenv: no se pudo ejecutar el binario.");
  console.error("Intenta reinstalar: npm install -g @delixon/nexenv");
  process.exit(1);
}
