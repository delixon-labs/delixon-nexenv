{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nexenv",
  "version": "1.0.0-beta.1",
  "identifier": "dev.delixon.nexenv",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": false,
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: data:; connect-src 'self' ipc: http://ipc.localhost"
    },
    "windows": [
      {
        "title": "Nexenv",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "center": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "createUpdaterArtifacts": false
  },
  "plugins": {
    "updater": {
      "active": false,
      "dialog": false,
      "endpoints": [
        "https://app.delixon.dev/api/nexenv/update/{{target}}/{{arch}}/{{current_version}}"
      ],
      "pubkey": "REEMPLAZAR_CON_LA_PUBLIC_KEY_GENERADA_POR_TAURI_SIGNER"
    }
  }
}
